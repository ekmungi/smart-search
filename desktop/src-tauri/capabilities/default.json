{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "search"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "global-shortcut:default",
    "global-shortcut:allow-register"
  ]
}
