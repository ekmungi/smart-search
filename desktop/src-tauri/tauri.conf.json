{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Smart Search",
  "version": "0.11.3",
  "identifier": "com.smartsearch.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Smart Search",
        "width": 960,
        "height": 640,
        "minWidth": 680,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      },
      {
        "label": "search",
        "title": "Quick Search",
        "width": 640,
        "height": 460,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "center": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/smart-search"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerHooks": "nsis-hooks.nsh"
      }
    }
  }
}
